APP_NAME=GenVideosAuto
API_PREFIX=/api

WORKSPACE_DIR=data
JOBS_DIR_NAME=jobs
MUSIC_PRESETS_DIR_NAME=music_presets
ENDING_CLIP_PATH=data/logo/ending.mp4

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

MAX_INPUT_CLIPS=10
MAX_OUTPUT_VERSIONS=10
MAX_CLIP_SIZE_MB=150
MAX_MUSIC_SIZE_MB=30

TARGET_WIDTH=1080
TARGET_HEIGHT=1920
TARGET_FPS=30
DEFAULT_TARGET_DURATION_SEC=22

CLEANUP_AFTER_HOURS=24

# Optional free tier key (do not commit real keys)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

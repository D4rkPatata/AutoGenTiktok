APP_NAME=GenVideosAuto
API_PREFIX=/api

WORKSPACE_DIR=data
JOBS_DIR_NAME=jobs
MUSIC_PRESETS_DIR_NAME=music_presets
ENDING_CLIP_PATH=data/logo/ending.mp4

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

MAX_INPUT_CLIPS=10
MAX_OUTPUT_VERSIONS=10
MAX_CLIP_SIZE_MB=150
MAX_MUSIC_SIZE_MB=30

TARGET_WIDTH=1080
TARGET_HEIGHT=1920
TARGET_FPS=30
DEFAULT_TARGET_DURATION_SEC=22

CLEANUP_AFTER_HOURS=24

# Optional free tier key (do not commit real keys)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Google OAuth2 (para login con Google y acceso a Drive)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tu-tunnel.trycloudflare.com/api/auth/callback
SESSION_SECRET=cambia-esto-por-un-string-aleatorio-largo


# URL pública de tu tunnel (sin barra final) — usada para que TikTok descargue videos via PULL_FROM_URL
PUBLIC_BASE_URL=https://tu-tunnel.trycloudflare.com

# TikTok OAuth2 (para login con TikTok)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://tu-tunnel.trycloudflare.com/api/auth/tiktok/callback

# TikTok drafts integration (access token manual, alternativa al OAuth)
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_DRAFT_ENDPOINT=https://open.tiktokapis.com/v2/post/publish/inbox/video/init/

# Jamendo — librería de música online gratuita (CC-licensed)
# Regístrate gratis en: devportal.jamendo.com → "My apps" → "Create new app" → copia el Client ID
JAMENDO_CLIENT_ID=
